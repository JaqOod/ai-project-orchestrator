{
  "name": "@orchestrator/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "snake": "pnpm -w run -r build && node --no-warnings dist/run-snake.js",
    "cli": "pnpm -w run -r build && node --no-warnings dist/run-cli.js",
    "orchestrate": "pnpm -w run -r build && node --no-warnings dist/run-spec.js",
    "amend": "pnpm -w run -r build && node --no-warnings dist/run-amend.js"
  },
  "dependencies": {
    "@orchestrator/core": "workspace:*",
    "@orchestrator/workers": "workspace:*",
    "puppeteer-core": "^25.3.0"
  }
}
